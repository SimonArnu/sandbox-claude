#!/usr/bin/env bash
# sandbox-start <name> [repo-url] [flags]
# Create a new agent container from a golden image, or restart a stopped one
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

# ── Parse args ──────────────────────────────────────────────────────
NAME=""
REPO=""
STACK="base"
BRANCH=""
FROM=""
SSH_KEY=""
SLOT=""
CPU=""
MEMORY=""
EXTRA_ENVS=()
ENV_FILES=()
RESTRICT_DOMAINS=""
DOMAINS_FILE=""
LOCAL_DIR=""
MCP_SERVERS=()
PLUGIN_MARKETPLACES=()
PLUGIN_INSTALLS=()
EXTRA_MOUNTS=()

# Track which values were explicitly set via CLI flags
declare -A CLI_SET=()

# Load a config file, applying values only if not already set by CLI.
# Format: key=value, one per line. Comments (#) and blank lines ignored.
# Supported keys: stack, branch, ssh-key, slot, cpu, memory, env,
#   env-file, local-dir, mcp, restrict-domains, domains-file
load_config() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# || -z "${line// }" ]] && continue
    local key="${line%%=*}"
    local value="${line#*=}"
    case "$key" in
      stack)            [[ -z "${CLI_SET[stack]:-}" ]] && STACK="$value" ;;
      branch)           [[ -z "${CLI_SET[branch]:-}" ]] && BRANCH="$value" ;;
      ssh-key)          [[ -z "${CLI_SET[ssh-key]:-}" ]] && SSH_KEY="$value" ;;
      slot)             [[ -z "${CLI_SET[slot]:-}" ]] && SLOT="$value" ;;
      cpu)              [[ -z "${CLI_SET[cpu]:-}" ]] && CPU="$value" ;;
      memory)           [[ -z "${CLI_SET[memory]:-}" ]] && MEMORY="$value" ;;
      local-dir)        [[ -z "${CLI_SET[local-dir]:-}" ]] && LOCAL_DIR="$value" ;;
      restrict-domains) [[ -z "${CLI_SET[restrict-domains]:-}" ]] && RESTRICT_DOMAINS="yes" ;;
      domains-file)     [[ -z "${CLI_SET[domains-file]:-}" ]] && RESTRICT_DOMAINS="yes" && DOMAINS_FILE="$value" ;;
      env)              EXTRA_ENVS+=("$value") ;;
      env-file)         ENV_FILES+=("$value") ;;
      mcp)              MCP_SERVERS+=("$value") ;;
      mount)            EXTRA_MOUNTS+=("$value") ;;
      plugin-marketplace) PLUGIN_MARKETPLACES+=("$value") ;;
      plugin)           PLUGIN_INSTALLS+=("$value") ;;
      *)                warn "Unknown config key in ${file}: ${key}" ;;
    esac
  done < "$file"
}

# ── Helpers ──────────────────────────────────────────────────────
apply_domain_filtering() {
  local container="$1" domains_file="$2"
  local resolved_file resolved_name container_ip

  resolved_file=$(resolve_domains_file "$domains_file")
  resolved_name=$(basename "$resolved_file")

  container_ip=$(get_container_ip "$container")
  [[ -n "$container_ip" ]] || die "Could not determine container IP for domain filtering"

  setup_container_domain_filter "$container" "$resolved_file" "$container_ip"
  redirect_container_to_squid "$container_ip"
  vm_exec "sudo iptables -I FORWARD -s '${container_ip}' -o '${OUTBOUND_IFACE}' -p udp --dport 443 -j DROP"

  ok "Domain filtering active (${resolved_name})"
}

inject_mcp_servers() {
  local container="$1"
  shift
  local servers=("$@")
  local claude_config_dir="${CLAUDE_CONFIG_DIR:-${HOME}/.claude}"
  local host_settings="${claude_config_dir}/settings.json"

  [[ -f "$host_settings" ]] || die "Claude settings not found: ${host_settings}"

  local selected_json
  selected_json=$(python3 -c "
import json, sys
with open('${host_settings}') as f:
    settings = json.load(f)
all_servers = settings.get('mcpServers', {})
requested = sys.argv[1:]
if 'all' in requested:
    selected = all_servers
else:
    selected = {}
    for name in requested:
        if name not in all_servers:
            print(f'MCP server \"{name}\" not found in {\"${host_settings}\"}', file=sys.stderr)
            sys.exit(1)
        selected[name] = all_servers[name]
print(json.dumps({'mcpServers': selected}, indent=2))
" "${servers[@]}") || die "Failed to extract MCP server configs"

  # Write settings.json into the container
  echo "$selected_json" | vm_run incus exec "${container}" -- \
    bash -c "mkdir -p ${SANDBOX_USER_HOME}/.claude && cat > ${SANDBOX_USER_HOME}/.claude/settings.json && chown -R ${SANDBOX_UID}:${SANDBOX_GID} ${SANDBOX_USER_HOME}/.claude"

  ok "MCP servers injected: ${servers[*]}"
}

print_connection_summary() {
  local container="$1" name="$2" status_word="$3"
  local slot stack_name ssh_p app_p alt_p

  slot=$(get_metadata "$container" "slot")
  stack_name=$(get_metadata "$container" "stack")
  ssh_p=$(ssh_port "$slot")
  app_p=$(app_port "$slot")
  alt_p=$(alt_port "$slot")

  echo ""
  ok "=== '${container}' ${status_word} ==="
  echo ""
  echo "  Slot:      ${slot}"
  echo "  Stack:     ${stack_name:-unknown}"
  if [[ "$(get_metadata "$container" "restrict-domains")" == "yes" ]]; then
    echo "  Domains:   RESTRICTED"
  else
    echo "  Domains:   open (all HTTPS allowed)"
  fi
  echo "  SSH:       ssh -o StrictHostKeyChecking=no -p ${ssh_p} ubuntu@localhost"
  echo "  VS Code:   code --remote ssh-remote+ubuntu@localhost:${ssh_p} ${WORKSPACE_DIR}"
  echo "  App:       http://localhost:${app_p}"
  echo "  Alt:       http://localhost:${alt_p}"
  echo ""
  echo "  Shell:     sandbox ${name}"
  echo "  Claude:    sandbox ${name} --claude"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --stack)            [[ -n "${2:-}" ]] || die "--stack requires a value"; STACK="$2"; CLI_SET[stack]=1; shift 2 ;;
    --branch)           [[ -n "${2:-}" ]] || die "--branch requires a value"; BRANCH="$2"; CLI_SET[branch]=1; shift 2 ;;
    --from)             [[ -n "${2:-}" ]] || die "--from requires a value"; FROM="$2"; shift 2 ;;
    --ssh-key)          [[ -n "${2:-}" ]] || die "--ssh-key requires a value"; SSH_KEY="$2"; CLI_SET[ssh-key]=1; shift 2 ;;
    --slot)             [[ -n "${2:-}" ]] || die "--slot requires a value"; SLOT="$2"; CLI_SET[slot]=1; shift 2 ;;
    --cpu)              [[ -n "${2:-}" ]] || die "--cpu requires a value"; CPU="$2"; CLI_SET[cpu]=1; shift 2 ;;
    --memory)           [[ -n "${2:-}" ]] || die "--memory requires a value"; MEMORY="$2"; CLI_SET[memory]=1; shift 2 ;;
    --env)              [[ -n "${2:-}" ]] || die "--env requires a value"; EXTRA_ENVS+=("$2"); shift 2 ;;
    --env-file)         [[ -n "${2:-}" ]] || die "--env-file requires a value"; ENV_FILES+=("$2"); shift 2 ;;
    --local-dir)        [[ -n "${2:-}" ]] || die "--local-dir requires a value"; LOCAL_DIR="$2"; CLI_SET[local-dir]=1; shift 2 ;;
    --mcp)              [[ -n "${2:-}" ]] || die "--mcp requires a value"; MCP_SERVERS+=("$2"); CLI_SET[mcp]=1; shift 2 ;;
    --mount)            [[ -n "${2:-}" ]] || die "--mount requires a value"; EXTRA_MOUNTS+=("$2"); shift 2 ;;
    --restrict-domains) RESTRICT_DOMAINS="yes"; CLI_SET[restrict-domains]=1; shift ;;
    --domains-file)     [[ -n "${2:-}" ]] || die "--domains-file requires a value"; RESTRICT_DOMAINS="yes"; DOMAINS_FILE="$2"; CLI_SET[domains-file]=1; shift 2 ;;
    --*)                die "Unknown flag: $1" ;;
    *)
      if [[ -z "$NAME" ]]; then
        NAME="$1"
      elif [[ -z "$REPO" ]]; then
        REPO="$1"
      else
        die "Unexpected argument: $1"
      fi
      shift
      ;;
  esac
done

[[ -n "$NAME" ]] || die "Usage: sandbox-start <name> [repo-url] [flags]"

# ── Load config files (global, then project — CLI flags always win) ─
# Save CLI-provided envs/env-files/mcp separately so config values layer underneath
CLI_ENVS=("${EXTRA_ENVS[@]+"${EXTRA_ENVS[@]}"}")
CLI_ENV_FILES=("${ENV_FILES[@]+"${ENV_FILES[@]}"}")
CLI_MCP=("${MCP_SERVERS[@]+"${MCP_SERVERS[@]}"}")
EXTRA_ENVS=()
ENV_FILES=()
if [[ -z "${CLI_SET[mcp]:-}" ]]; then
  MCP_SERVERS=()
fi

SANDBOX_GLOBAL_CONFIG="${SANDBOX_CONFIG:-${HOME}/.sandbox/config}"
load_config "$SANDBOX_GLOBAL_CONFIG"

# Resolve local-dir early so we can find .sandbox.conf
if [[ -n "$LOCAL_DIR" ]]; then
  _RESOLVED_LOCAL="$(cd "$LOCAL_DIR" 2>/dev/null && pwd)" || true
  if [[ -n "$_RESOLVED_LOCAL" && -f "${_RESOLVED_LOCAL}/.sandbox.conf" ]]; then
    load_config "${_RESOLVED_LOCAL}/.sandbox.conf"
  fi
fi

# Restore CLI values on top (CLI env-files, CLI envs last so they win)
ENV_FILES+=(${CLI_ENV_FILES[@]+"${CLI_ENV_FILES[@]}"})
if [[ -n "${CLI_SET[mcp]:-}" ]]; then
  MCP_SERVERS=("${CLI_MCP[@]}")
fi

# ── Read --env-file(s), then append --env overrides on top ────────
if [[ ${#ENV_FILES[@]} -gt 0 ]]; then
  FILE_ENVS=()
  for ef in "${ENV_FILES[@]}"; do
    [[ -f "$ef" ]] || die "Env file not found: ${ef}"
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ "$line" =~ ^[[:space:]]*# || -z "${line// }" ]] && continue
      FILE_ENVS+=("$line")
    done < "$ef"
  done
  EXTRA_ENVS+=(${FILE_ENVS[@]+"${FILE_ENVS[@]}"})
fi

# CLI --env values go last (highest precedence)
EXTRA_ENVS+=(${CLI_ENVS[@]+"${CLI_ENVS[@]}"})

# ── Validate --local-dir ──────────────────────────────────────────
if [[ -n "$LOCAL_DIR" ]]; then
  [[ -z "$REPO" ]] || die "Cannot use --local-dir with a repo URL"
  LOCAL_DIR="$(cd "$LOCAL_DIR" 2>/dev/null && pwd)" || die "Directory not found: ${LOCAL_DIR}"
  [[ -d "$LOCAL_DIR" ]] || die "Not a directory: ${LOCAL_DIR}"
fi

# ── Validate --mount entries ──────────────────────────────────────
for m in "${EXTRA_MOUNTS[@]+"${EXTRA_MOUNTS[@]}"}"; do
  [[ "$m" == *:* ]] || die "Invalid --mount format '${m}'. Expected source:dest"
  local_src="${m%%:*}"
  [[ -d "$local_src" ]] || die "Mount source not found: ${local_src}"
done

# ── Check for existing container (restart-or-create) ──────────────
require_sandbox
CONTAINER=$(container_name "$NAME")

CONTAINER_STATE=""
if vm_exec "incus info ${CONTAINER} &>/dev/null" 2>/dev/null; then
  CONTAINER_STATE=$(vm_exec "incus info ${CONTAINER} 2>/dev/null | grep 'Status:' | awk '{print \$2}'" || true)
fi

if [[ "$CONTAINER_STATE" == "RUNNING" ]]; then
  die "Container '${CONTAINER}' is already running. Use 'sandbox ${NAME}' to connect."
fi

if [[ "$CONTAINER_STATE" == "STOPPED" ]]; then
  # ── Restart path: reconfigure in-place ────────────────────────────
  info "Restarting stopped container '${CONTAINER}'..."

  # Error on flags that can't be changed in-place
  IMMUTABLE_ERROR=""
  [[ "$STACK" != "base" ]] && IMMUTABLE_ERROR+="  --stack (cannot change stack on restart)\n"
  [[ -n "$FROM" ]]         && IMMUTABLE_ERROR+="  --from (cannot change source on restart)\n"
  [[ -n "$REPO" ]]         && IMMUTABLE_ERROR+="  --repo (cannot change repo on restart)\n"
  [[ -n "$BRANCH" ]]       && IMMUTABLE_ERROR+="  --branch (cannot change branch on restart)\n"
  [[ -n "$SLOT" ]]         && IMMUTABLE_ERROR+="  --slot (cannot change slot on restart)\n"
  [[ -n "$LOCAL_DIR" ]]    && IMMUTABLE_ERROR+="  --local-dir (cannot change mount on restart)\n"
  [[ ${#EXTRA_MOUNTS[@]} -gt 0 ]] && IMMUTABLE_ERROR+="  --mount (cannot change mounts on restart)\n"
  if [[ -n "$IMMUTABLE_ERROR" ]]; then
    die "Cannot change these flags on restart (destroy and recreate instead):\n${IMMUTABLE_ERROR}Use 'sandbox-stop ${NAME} --rm' first, then 'sandbox-start ${NAME} ...' to recreate."
  fi

  # Start the container
  vm_exec "incus start ${CONTAINER}"

  # Wait for networking
  wait_for_container_networking "$CONTAINER"

  # Ensure workspace directory exists (may be missing in containers from old golden images)
  vm_exec "incus exec ${CONTAINER} -- bash -c 'mkdir -p ${WORKSPACE_DIR} && chown ${SANDBOX_UID}:${SANDBOX_GID} ${WORKSPACE_DIR}'"

  # Apply reconfigurable flags if provided
  if [[ -n "$CPU" ]]; then
    info "Updating CPU limit to ${CPU}..."
    vm_exec "incus config set ${CONTAINER} limits.cpu=${CPU}"
  fi
  if [[ -n "$MEMORY" ]]; then
    info "Updating memory limit to ${MEMORY}..."
    vm_exec "incus config set ${CONTAINER} limits.memory=${MEMORY}"
  fi

  # Inject extra env vars (appends new ones to bashrc)
  if [[ ${#EXTRA_ENVS[@]} -gt 0 ]]; then
    info "Injecting environment variables..."
    inject_env "$CONTAINER" ${EXTRA_ENVS[@]+"${EXTRA_ENVS[@]}"}
  fi

  # Handle --ssh-key: replace deploy key in container and update SSH config
  if [[ -n "$SSH_KEY" ]]; then
    [[ -f "$SSH_KEY" ]] || die "SSH key not found: ${SSH_KEY}"
    info "Replacing SSH key..."
    ssh_agent_cleanup "$CONTAINER"
    ssh_agent_setup "$CONTAINER" "$SSH_KEY"
  else
    # Restart SSH agent using existing key on disk
    info "Restarting SSH agent..."
    ssh_agent_restart "$CONTAINER"
  fi

  # Handle domain filtering updates
  if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
    info "Applying domain-based egress filtering..."
    apply_domain_filtering "$CONTAINER" "$DOMAINS_FILE"
    set_metadata "$CONTAINER" "restrict-domains" "yes"
    [[ -n "$DOMAINS_FILE" ]] && set_metadata "$CONTAINER" "domains-file" "$DOMAINS_FILE"
  else
    EXISTING_RESTRICT=$(get_metadata "$CONTAINER" "restrict-domains")
    if [[ "$EXISTING_RESTRICT" == "yes" ]]; then
      info "Re-applying domain filtering from saved configuration..."
      EXISTING_DOMAINS_FILE=$(get_metadata "$CONTAINER" "domains-file")
      apply_domain_filtering "$CONTAINER" "$EXISTING_DOMAINS_FILE"
    fi
  fi

  print_connection_summary "$CONTAINER" "$NAME" "restarted"
  exit 0
fi

# ── Container doesn't exist: create from scratch ──────────────────

# ── Resolve --from ──────────────────────────────────────────────────
if [[ -n "$FROM" ]]; then
  FROM_CONTAINER=$(container_name "$FROM")

  if [[ -z "$REPO" ]]; then
    REPO=$(vm_exec "incus exec ${FROM_CONTAINER} -- git -c safe.directory=${WORKSPACE_DIR} -C ${WORKSPACE_DIR} remote get-url origin 2>/dev/null" || true)
    [[ -n "$REPO" ]] || die "Could not determine repo URL from container '${FROM_CONTAINER}'"
    info "Inherited repo: ${REPO}"
  fi

  if [[ "$STACK" == "base" ]]; then
    FROM_STACK=$(get_metadata "$FROM_CONTAINER" "stack")
    if [[ -n "$FROM_STACK" ]]; then
      STACK="$FROM_STACK"
      info "Inherited stack: ${STACK}"
    fi
  fi

  if [[ -z "$SSH_KEY" ]]; then
    FROM_KEY="${SANDBOX_KEY_DIR}/deploy_${FROM}"
    if [[ -f "$FROM_KEY" ]]; then
      # Don't reuse the key — generate a new one for this container
      info "Will generate new deploy key (not reusing from '${FROM}')"
    fi
  fi

  # Inherit domain restriction if not explicitly set
  if [[ -z "$RESTRICT_DOMAINS" ]]; then
    FROM_RESTRICT=$(get_metadata "$FROM_CONTAINER" "restrict-domains")
    if [[ "$FROM_RESTRICT" == "yes" ]]; then
      RESTRICT_DOMAINS="yes"
      info "Inherited domain restriction from '${FROM}'"
      if [[ -z "$DOMAINS_FILE" ]]; then
        FROM_DOMAINS_FILE=$(get_metadata "$FROM_CONTAINER" "domains-file")
        if [[ -n "$FROM_DOMAINS_FILE" ]]; then
          DOMAINS_FILE="$FROM_DOMAINS_FILE"
          info "Inherited domains file: ${DOMAINS_FILE}"
        fi
      fi
    fi
  fi
fi

# ── Validate ────────────────────────────────────────────────────────
require_golden "$STACK"

# ── Auto-assign or validate slot ────────────────────────────────────
if [[ -z "$SLOT" ]]; then
  SLOT=$(next_free_slot)
  info "Auto-assigned slot: ${SLOT}"
else
  validate_slot "$SLOT"
fi

SSH_P=$(ssh_port "$SLOT")
APP_P=$(app_port "$SLOT")
ALT_P=$(alt_port "$SLOT")

# ── Deploy key (auto-generate if repo provided and no --ssh-key) ───
KEY_PATH=""
if [[ -n "$REPO" && -z "$SSH_KEY" ]]; then
  require_gh
  deploy_key_create "$NAME" "$REPO"
  KEY_PATH="${SANDBOX_KEY_DIR}/deploy_${NAME}"
elif [[ -n "$SSH_KEY" ]]; then
  [[ -f "$SSH_KEY" ]] || die "SSH key not found: ${SSH_KEY}"
  KEY_PATH="$SSH_KEY"
fi

# ── Create container ────────────────────────────────────────────────
info "Creating '${CONTAINER}' from golden-${STACK}/ready (slot ${SLOT})..."

vm_exec "
  incus copy golden-${STACK}/ready ${CONTAINER}
"

# Resource limits (only if explicitly set)
if [[ -n "$CPU" ]]; then
  vm_exec "incus config set ${CONTAINER} limits.cpu=${CPU}"
fi
if [[ -n "$MEMORY" ]]; then
  vm_exec "incus config set ${CONTAINER} limits.memory=${MEMORY}"
fi

# Proxy devices for port forwarding
vm_exec "
  incus config device add ${CONTAINER} ssh-proxy proxy \
    listen=tcp:127.0.0.1:${SSH_P} connect=tcp:127.0.0.1:22

  incus config device add ${CONTAINER} app-proxy proxy \
    listen=tcp:127.0.0.1:${APP_P} connect=tcp:127.0.0.1:8080

  incus config device add ${CONTAINER} alt-proxy proxy \
    listen=tcp:127.0.0.1:${ALT_P} connect=tcp:127.0.0.1:9090
"

# Bind-mount host directory if --local-dir
if [[ -n "$LOCAL_DIR" ]]; then
  info "Mounting ${LOCAL_DIR} → ${WORKSPACE_DIR}..."
  vm_exec "incus config device add ${CONTAINER} workspace disk source=${LOCAL_DIR} path=${WORKSPACE_DIR} shift=true"
fi

# Extra bind-mounts via --mount
if [[ ${#EXTRA_MOUNTS[@]} -gt 0 ]]; then
  _mount_idx=0
  for m in "${EXTRA_MOUNTS[@]}"; do
    _src="${m%%:*}"
    _dest="${m#*:}"
    _src="$(cd "$_src" && pwd)"
    _device="mount-${_mount_idx}"
    info "Mounting ${_src} → ${_dest}..."
    vm_exec "incus config device add ${CONTAINER} ${_device} disk source=${_src} path=${_dest} shift=true"
    _mount_idx=$((_mount_idx + 1))
  done
fi

# Start
vm_exec "incus start ${CONTAINER}"
vm_exec "sleep 3"

# ── Host SSH key (for user SSH access) ────────────────────────────
HOST_PUBKEY=""
for keyfile in ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub ~/.ssh/id_ecdsa.pub; do
  if [[ -f "$keyfile" ]]; then
    HOST_PUBKEY=$(cat "$keyfile")
    break
  fi
done
if [[ -n "$HOST_PUBKEY" ]]; then
  # Inject for ubuntu user (primary SSH access)
  echo "$HOST_PUBKEY" | vm_run incus exec "${CONTAINER}" -- \
    bash -c "cat >> ${SANDBOX_USER_HOME}/.ssh/authorized_keys && chmod 600 ${SANDBOX_USER_HOME}/.ssh/authorized_keys && chown ${SANDBOX_UID}:${SANDBOX_GID} ${SANDBOX_USER_HOME}/.ssh/authorized_keys"
  # Keep root too for emergency access
  echo "$HOST_PUBKEY" | vm_run incus exec "${CONTAINER}" -- \
    bash -c 'cat >> /root/.ssh/authorized_keys && chmod 600 /root/.ssh/authorized_keys'
  ok "Host SSH key injected"
else
  warn "No SSH public key found (~/.ssh/id_*.pub) — SSH access requires manual key setup"
fi

# ── SSH agent ───────────────────────────────────────────────────────
if [[ -n "$KEY_PATH" ]]; then
  info "Setting up SSH agent..."
  ssh_agent_setup "$CONTAINER" "$KEY_PATH"
fi

# ── Env vars ────────────────────────────────────────────────────────
inject_env "$CONTAINER" ${EXTRA_ENVS[@]+"${EXTRA_ENVS[@]}"}

# ── Claude config injection (CLAUDE.md + supporting files) ────────
SANDBOX_CLAUDE_MD="${HOME}/.sandbox/claude.md"
if [[ -f "$SANDBOX_CLAUDE_MD" ]]; then
  info "Injecting sandbox CLAUDE.md..."
  vm_run incus exec "${CONTAINER}" -- mkdir -p "${SANDBOX_USER_HOME}/.claude"
  vm_run incus file push "$SANDBOX_CLAUDE_MD" "${CONTAINER}${SANDBOX_USER_HOME}/.claude/CLAUDE.md" \
    --uid=${SANDBOX_UID} --gid=${SANDBOX_GID}
  # Inject any supporting files referenced by CLAUDE.md
  for f in "${HOME}/.sandbox/"*.md; do
    [[ "$(basename "$f")" == "claude.md" ]] && continue
    [[ -f "$f" ]] || continue
    vm_run incus file push "$f" "${CONTAINER}${SANDBOX_USER_HOME}/.claude/$(basename "$f")" \
      --uid=${SANDBOX_UID} --gid=${SANDBOX_GID}
  done
  ok "Claude config injected"
fi

# ── MCP servers ────────────────────────────────────────────────────
if [[ ${#MCP_SERVERS[@]} -gt 0 ]]; then
  info "Injecting MCP server configuration..."
  inject_mcp_servers "$CONTAINER" "${MCP_SERVERS[@]}"
fi

# ── Claude plugins ─────────────────────────────────────────────────
if [[ ${#PLUGIN_MARKETPLACES[@]} -gt 0 || ${#PLUGIN_INSTALLS[@]} -gt 0 ]]; then
  info "Installing Claude Code plugins..."
  for marketplace in "${PLUGIN_MARKETPLACES[@]+"${PLUGIN_MARKETPLACES[@]}"}"; do
    vm_run incus exec "${CONTAINER}" --user ${SANDBOX_UID} --group ${SANDBOX_GID} --env HOME=${SANDBOX_USER_HOME} -- \
      bash -lc "claude plugin marketplace add '${marketplace}'" \
      || warn "Failed to add marketplace: ${marketplace}"
  done
  for plugin in "${PLUGIN_INSTALLS[@]+"${PLUGIN_INSTALLS[@]}"}"; do
    vm_run incus exec "${CONTAINER}" --user ${SANDBOX_UID} --group ${SANDBOX_GID} --env HOME=${SANDBOX_USER_HOME} -- \
      bash -lc "claude plugin install '${plugin}'" \
      || warn "Failed to install plugin: ${plugin}"
  done
  ok "Claude plugins installed"
fi

# ── Domain filtering ───────────────────────────────────────────────
if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
  info "Applying domain-based egress filtering..."
  apply_domain_filtering "$CONTAINER" "$DOMAINS_FILE"
fi

# ── Store metadata ──────────────────────────────────────────────────
set_metadata "$CONTAINER" "slot" "$SLOT"
set_metadata "$CONTAINER" "stack" "$STACK"
[[ -n "$REPO" ]] && set_metadata "$CONTAINER" "repo" "$REPO"
[[ -n "$LOCAL_DIR" ]] && set_metadata "$CONTAINER" "local-dir" "$LOCAL_DIR"
if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
  set_metadata "$CONTAINER" "restrict-domains" "yes"
  [[ -n "$DOMAINS_FILE" ]] && set_metadata "$CONTAINER" "domains-file" "$DOMAINS_FILE"
fi

# ── Clone repo ──────────────────────────────────────────────────────
if [[ -n "$REPO" ]]; then
  info "Cloning repository..."

  # Configure safe.directory for ubuntu user and clone as ubuntu
  vm_run incus exec "${CONTAINER}" --user ${SANDBOX_UID} --group ${SANDBOX_GID} --env HOME=${SANDBOX_USER_HOME} -- \
    bash -c "git config --global safe.directory '*' && SSH_AUTH_SOCK=/run/ssh-agent.sock git clone ${REPO} ${WORKSPACE_DIR}" \
    || die "Git clone failed. Check SSH key and repo access."

  # Switch to requested branch (checkout if it exists remotely, create if it doesn't)
  if [[ -n "$BRANCH" ]]; then
    vm_run incus exec "${CONTAINER}" --user ${SANDBOX_UID} --group ${SANDBOX_GID} --env HOME=${SANDBOX_USER_HOME} -- \
      bash -c "cd ${WORKSPACE_DIR} && git checkout ${BRANCH} 2>/dev/null || git checkout -b ${BRANCH}" \
      || die "Failed to switch to branch '${BRANCH}'"
    ok "Repository cloned (branch: ${BRANCH})"
  else
    ok "Repository cloned"
  fi
fi

# Ensure workspace directory exists for scratch containers (no repo, no local-dir)
if [[ -z "$REPO" && -z "$LOCAL_DIR" ]]; then
  vm_run incus exec "${CONTAINER}" --user ${SANDBOX_UID} --group ${SANDBOX_GID} -- \
    mkdir -p "${WORKSPACE_DIR}"
fi

# ── Done ────────────────────────────────────────────────────────────
print_connection_summary "$CONTAINER" "$NAME" "ready"
